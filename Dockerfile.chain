FROM golang:1.22-alpine AS builder

RUN apk add --no-cache make gcc musl-dev git

WORKDIR /build
COPY chain/ .
RUN go build -mod=vendor -o /clawchaind ./cmd/clawchaind

FROM alpine:3.19
RUN apk add --no-cache ca-certificates
COPY --from=builder /clawchaind /usr/local/bin/
EXPOSE 26656 26657 9090 1317

ENTRYPOINT ["clawchaind"]
CMD ["start"]
